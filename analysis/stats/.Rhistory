)
if (!is.null(fit)) {
print(summary(fit))
cat("\n--- Anova (Type III) ---\n")
print(anova(fit))
lmer_list[[reg]] <- fit
# Extract age_c main effect + model_type:age_c interaction betas
coefs      <- as.data.frame(summary(fit)$coefficients)
coefs$term <- rownames(coefs)
age_rows   <- coefs[grepl("age_c", coefs$term), ]
age_rows$model_type <- sub(":age_c|age_c:", "", age_rows$term)
age_rows$model_type <- ifelse(age_rows$model_type == "age_c", "z_speech",
gsub("model_type", "", age_rows$model_type))
age_rows$region     <- reg
beta_list[[reg]]    <- age_rows[, c("region", "model_type",
"Estimate", "Std. Error", "Pr(>|t|)")]
# Predicted values back-transformed to real age
pred             <- as.data.frame(ggpredict(fit, terms = c("age_c [all]", "model_type")))
colnames(pred)[colnames(pred) == "group"] <- "model_type"
pred$real_age    <- exp(pred$x + mean_log_age)
pred$region      <- reg
pred$model_type  <- factor(pred$model_type, levels = model_vars)
pred_list[[reg]] <- pred
}
}
sink()
message("Stats written to: ", stats_path)
# Combine predictions and betas across regions
pred_all        <- do.call(rbind, pred_list)
pred_all$region <- factor(pred_all$region, levels = regions)
beta_df                <- do.call(rbind, beta_list)
rownames(beta_df)      <- NULL
colnames(beta_df)[3:5] <- c("beta", "se", "pval")
beta_df$model_clean    <- factor(beta_df$model_type, levels = model_vars)
beta_df$region         <- factor(beta_df$region, levels = regions)
# Shared axis limits across all regions
pad <- function(r, pct = 0.05) r + c(-1, 1) * diff(r) * pct
y_main_lim  <- pad(range(c(pred_all$conf.low,  pred_all$conf.high),  na.rm = TRUE))
y_inset_lim <- pad(range(c(beta_df$beta - beta_df$se, beta_df$beta + beta_df$se), na.rm = TRUE))
x_lim       <- pad(range(pred_all$real_age, na.rm = TRUE))
# Legend shows lines only, no filled boxes
line_legend <- guides(
color = guide_legend(override.aes = list(linewidth = 1.5, fill = NA)),
fill  = "none"
)
base_theme <- theme_classic(base_size = 11, base_family = "Arial") +
theme(
text            = element_text(family = "Arial"),
axis.title      = element_text(size = 11, family = "Arial"),
axis.text       = element_text(size = 9,  family = "Arial"),
legend.title    = element_blank(),
legend.text     = element_text(size = 9,  family = "Arial"),
legend.position = "right",
legend.key      = element_blank()
)
inset_theme <- theme_classic(base_size = 8, base_family = "Arial") +
theme(
text            = element_text(family = "Arial"),
legend.position = "none",
axis.text.x     = element_text(angle = 30, hjust = 1, size = 7, family = "Arial"),
axis.title      = element_text(size = 8, family = "Arial")
)
# One figure per ROI with top-left inset
for (reg in regions) {
pred_reg <- pred_all[pred_all$region == reg, ]
beta_reg <- beta_df[beta_df$region   == reg, ]
p_main <- ggplot(pred_reg,
aes(x = real_age, y = predicted,
color = model_type, fill = model_type)) +
geom_ribbon(aes(ymin = conf.low, ymax = conf.high),
alpha = 0.15, color = NA) +
geom_line(linewidth = 1.1) +
scale_x_log10(
name   = "Age (years, log scale)",
breaks = c(5, 10, 20, 40, 80),
labels = c("5", "10", "20", "40", "80"),
limits = x_lim
) +
scale_y_continuous(name   = "Fisher Z-transformed Correlation",
limits = y_main_lim) +
scale_color_manual(values = model_colors, labels = model_labels) +
scale_fill_manual(values  = model_colors, labels = model_labels) +
line_legend +
base_theme
p_inset <- ggplot(beta_reg,
aes(x = model_clean, y = beta,
color = model_clean, fill = model_clean)) +
geom_hline(yintercept = 0, linetype = "solid", color = "black", linewidth = 0.3) +
geom_col(alpha = 0.75, width = 0.55, color = NA) +
geom_errorbar(aes(ymin = beta - se, ymax = beta + se),
width = 0.2, linewidth = 0.6) +
scale_x_discrete(labels = model_labels) +
scale_y_continuous(name   = expression(beta[age]),
limits = y_inset_lim) +
scale_color_manual(values = model_colors) +
scale_fill_manual(values  = model_colors) +
# labs(x = "Model") +
inset_theme
p_out <- p_main +
inset_element(p_inset,
left   = 0.05,
bottom = 0.70,
right  = 0.31,
top    = 1.00)
ggsave(file.path(save_dir, sprintf("speech_music_age_lmer_%s.pdf", reg)),
plot = p_out, width = 7, height = 5, device = cairo_pdf)
ggsave(file.path(save_dir, sprintf("speech_music_age_lmer_%s.png", reg)),
plot = p_out, width = 7, height = 5, dpi = 300)
}
message("All figures saved to: ", save_dir)
# Speech vs Music Selectivity – LMER Analysis & Visualization
# Model: correlation ~ model_type * age_c + sex + (1 | subj_id)
library(lmerTest)
library(reshape2)
library(ggplot2)
library(extrafont)
loadfonts(device = "pdf")
library(patchwork)
library(ggeffects)
library(dplyr)
# Paths
data_path  <- "/Users/rajviagravat/Documents/Hamilton_Lab/Code/speechMusic/analysis/plotting/DNN_analysis/DNN_analysis_allmodels_03_05.csv"
stats_path <- "/Users/rajviagravat/Library/CloudStorage/Box-Box/Figures/fig4_neg_filter_NEW/LMER_03_03_log_age_c_int_atanh_neg_filter_.txt"
save_dir   <- "/Users/rajviagravat/Library/CloudStorage/Box-Box/Figures/fig4_neg_filter_NEW"
dir.create(save_dir, recursive = TRUE, showWarnings = FALSE)
# Data loading and preprocessing
data            <- read.csv(data_path, header = TRUE)
data$short_anat <- as.factor(data$short_anat)
data$age_c      <- scale(log(data$age), center = TRUE, scale = FALSE)
# Fisher Z-transform correlations
data$z_speech  <- atanh(data$speech_only_corrs_DNN)
data$z_music   <- atanh(data$music_only_corrs_DNN)
data$z_mixed   <- atanh(data$speech_music_corrs_DNN)
data$z_stacked <- atanh(data$stacked_corrs_DNN)
# Keep rows where at least one model has a positive raw correlation
data_filt <- data[(data$speech_music_corrs_DNN > 0) |
(data$music_only_corrs_DNN  > 0) |
(data$speech_only_corrs_DNN  > 0) |
(data$stacked_corrs_DNN      > 0), ]
# Settings
regions      <- c("STG", "STS", "MTG", "HG", "PP", "PT")
model_vars   <- c("z_speech", "z_mixed", "z_music", "z_stacked")
model_colors <- c(z_speech  = "#c51b7d",
z_mixed   = "#f4883c",
z_music   = "#276419",
z_stacked = "#ffbf00")
model_labels <- c(z_speech  = "Speech",
z_mixed   = "Mixed",
z_music   = "Music",
z_stacked = "Stacked")
# Reshape to long format
data_long <- melt(
data_filt,
id.vars       = c("subj_id", "age", "age_c", "sex", "short_anat"),
measure.vars  = model_vars,
variable.name = "model_type",
value.name    = "correlation"
)
data_long$model_type <- factor(data_long$model_type, levels = model_vars)
data_long$short_anat <- factor(data_long$short_anat, levels = regions)
# Mean log age for back-transforming age_c to real age
mean_log_age <- mean(log(data_filt$age), na.rm = TRUE)
# Run per-region LMERs, collect stats, predicted values, and betas
sink(stats_path)
lmer_list <- list()
beta_list <- list()
pred_list <- list()
for (reg in regions) {
cat(sprintf("\n=== Region: %s ===\n", reg))
d_reg <- data_long[data_long$short_anat == reg, ]
fit <- tryCatch(
lmer(correlation ~ model_type * age_c + sex + (1 | subj_id),
data = d_reg, REML = FALSE),
error = function(e) { cat("Model failed:", conditionMessage(e), "\n"); NULL }
)
if (!is.null(fit)) {
print(summary(fit))
cat("\n--- Anova (Type III) ---\n")
print(anova(fit))
lmer_list[[reg]] <- fit
# Extract age_c main effect + model_type:age_c interaction betas
coefs      <- as.data.frame(summary(fit)$coefficients)
coefs$term <- rownames(coefs)
age_rows   <- coefs[grepl("age_c", coefs$term), ]
age_rows$model_type <- sub(":age_c|age_c:", "", age_rows$term)
age_rows$model_type <- ifelse(age_rows$model_type == "age_c", "z_speech",
gsub("model_type", "", age_rows$model_type))
age_rows$region     <- reg
beta_list[[reg]]    <- age_rows[, c("region", "model_type",
"Estimate", "Std. Error", "Pr(>|t|)")]
# Predicted values back-transformed to real age
pred             <- as.data.frame(ggpredict(fit, terms = c("age_c [all]", "model_type")))
colnames(pred)[colnames(pred) == "group"] <- "model_type"
pred$real_age    <- exp(pred$x + mean_log_age)
pred$region      <- reg
pred$model_type  <- factor(pred$model_type, levels = model_vars)
pred_list[[reg]] <- pred
}
}
sink()
message("Stats written to: ", stats_path)
# Combine predictions and betas across regions
pred_all        <- do.call(rbind, pred_list)
pred_all$region <- factor(pred_all$region, levels = regions)
beta_df                <- do.call(rbind, beta_list)
rownames(beta_df)      <- NULL
colnames(beta_df)[3:5] <- c("beta", "se", "pval")
beta_df$model_clean    <- factor(beta_df$model_type, levels = model_vars)
beta_df$region         <- factor(beta_df$region, levels = regions)
# Shared axis limits across all regions
pad <- function(r, pct = 0.05) r + c(-1, 1) * diff(r) * pct
y_main_lim  <- pad(range(c(pred_all$conf.low,  pred_all$conf.high),  na.rm = TRUE))
y_inset_lim <- pad(range(c(beta_df$beta - beta_df$se, beta_df$beta + beta_df$se), na.rm = TRUE))
x_lim       <- pad(range(pred_all$real_age, na.rm = TRUE))
# Legend shows lines only, no filled boxes
line_legend <- guides(
color = guide_legend(override.aes = list(linewidth = 1.5, fill = NA)),
fill  = "none"
)
base_theme <- theme_classic(base_size = 11, base_family = "Arial") +
theme(
text            = element_text(family = "Arial"),
axis.title      = element_text(size = 11, family = "Arial"),
axis.text       = element_text(size = 9,  family = "Arial"),
legend.title    = element_blank(),
legend.text     = element_text(size = 9,  family = "Arial"),
legend.position = "right",
legend.key      = element_blank()
)
inset_theme <- theme_classic(base_size = 8, base_family = "Arial") +
theme(
text            = element_text(family = "Arial"),
legend.position = "none",
axis.text.x     = element_text(angle = 30, hjust = 1, size = 7, family = "Arial"),
axis.title      = element_text(size = 8, family = "Arial")
)
# One figure per ROI with top-left inset
for (reg in regions) {
pred_reg <- pred_all[pred_all$region == reg, ]
beta_reg <- beta_df[beta_df$region   == reg, ]
p_main <- ggplot(pred_reg,
aes(x = real_age, y = predicted,
color = model_type, fill = model_type)) +
geom_ribbon(aes(ymin = conf.low, ymax = conf.high),
alpha = 0.15, color = NA) +
geom_line(linewidth = 1.1) +
scale_x_log10(
name   = "Age (years, log scale)",
breaks = c(5, 10, 20, 40, 80),
labels = c("5", "10", "20", "40", "80"),
limits = x_lim
) +
scale_y_continuous(name   = "Fisher Z-transformed Correlation",
limits = y_main_lim) +
scale_color_manual(values = model_colors, labels = model_labels) +
scale_fill_manual(values  = model_colors, labels = model_labels) +
line_legend +
base_theme
p_inset <- ggplot(beta_reg,
aes(x = model_clean, y = beta,
color = model_clean, fill = model_clean)) +
geom_hline(yintercept = 0, linetype = "solid", color = "black", linewidth = 0.3) +
geom_col(alpha = 0.75, width = 0.55, color = NA) +
geom_errorbar(aes(ymin = beta - se, ymax = beta + se),
width = 0.2, linewidth = 0.6) +
scale_x_discrete(labels = model_labels) +
scale_y_continuous(name   = expression(beta[age]),
limits = y_inset_lim) +
scale_color_manual(values = model_colors) +
scale_fill_manual(values  = model_colors) +
labs(x = "") +
inset_theme
p_out <- p_main +
inset_element(p_inset,
left   = 0.05,
bottom = 0.70,
right  = 0.31,
top    = 1.00)
ggsave(file.path(save_dir, sprintf("speech_music_age_lmer_%s.pdf", reg)),
plot = p_out, width = 7, height = 5, device = cairo_pdf)
ggsave(file.path(save_dir, sprintf("speech_music_age_lmer_%s.png", reg)),
plot = p_out, width = 7, height = 5, dpi = 300)
}
message("All figures saved to: ", save_dir)
# Load libraries
library(lmerTest)
library(reshape2)
library(sjPlot)
library(ggplot2)
library(extrafont)
loadfonts(device = "pdf")
library(ggeffects)
# Read data
data <- read.csv("/Users/rajviagravat/Documents/Hamilton_Lab/Code/speechMusic/analysis/plotting/DNN_analysis/DNN_analysis_allmodels_03_05.csv", header = TRUE)
data$short_anat <- as.factor(data$short_anat)
data$age_c <- scale(log(data$age), center=TRUE, scale=FALSE) # Need to center because there is an interaction
# Compute difference scores
data$speech_only_diff <- data$speech_only_corrs_DNN - data$speech_music_corrs_DNN
data$music_only_diff <- data$music_only_corrs_DNN - data$speech_music_corrs_DNN
# R to Z transform
data$z_speech = atanh(data$speech_only_corrs_DNN)
data$z_music = atanh(data$music_only_corrs_DNN)
data$z_mixed = atanh(data$speech_music_corrs_DNN)
data$z_stacked = atanh(data$stacked_corrs_DNN)
# Filter low-correlation data
data_filt <- data[(data$speech_music_corrs_DNN > 0.0) |
(data$music_only_corrs_DNN > 0.0) |
(data$speech_only_corrs_DNN > 0.0) |
(data$stacked_corrs_DNN > 0.0), ]
# Define regions
regions <- c('STG','STS','MTG','HG','PP','PT')
# Define reference levels for Model 1
ref_levels <- c("z_speech", "z_mixed",
"z_music", "z_stacked")
save_dir <- "/Users/rajviagravat/Library/CloudStorage/Box-Box/Figures/fig4_FINAL"
dir.create(save_dir, recursive = TRUE, showWarnings = FALSE)
log_age_mean <- mean(log(data_filt$age), na.rm = TRUE)
# Melt all regions together to get global x-axis (age) range for consistent
# x-axis limits across all ROI plots — not used for modeling
melted_all <- melt(data_filt,
id.vars = c("subj_id", "anat", "short_anat", "age_c", "dev", "sex", "x", "y", "z"),
measure.vars = c("z_speech", "z_mixed", "z_music", "z_stacked"),
variable.name = "model_type",
value.name = "correlation")
# Compute global x-axis range
x_min <- min(melted_all$age_c, na.rm = TRUE)
x_max <- max(melted_all$age_c, na.rm = TRUE)
# Open text file to capture output
sink(file.path(save_dir, "LMER_03_03_log_age_c_int_atanh_neg_filter_.txt"))
for (anat in regions) {
data_anat <- data_filt[data_filt$short_anat == anat, ]
cat("\n", rep("=", 60), "\n", sep = "")
cat("REGION:", anat, "\n")
cat(rep("=", 60), "\n\n", sep = "")
# Model 1: Combined with all reference levels
melted_data <- melt(data_anat,
id.vars = c("subj_id", "anat", "short_anat", "age_c", "dev", "sex", "x", "y", "z"),
measure.vars = c("z_speech", "z_mixed",
"z_music", "z_stacked"),
variable.name = "model_type",
value.name = "correlation")
melted_data <- melted_data[melted_data$correlation > 0, ] # remove negative z-scores per model type
for (ref in ref_levels) {
melted_data$model_type <- relevel(melted_data$model_type, ref = ref)
model1 <- lmer(correlation ~ model_type*age_c + sex + (1 | subj_id), data = melted_data)
# Only generate and save plot for z_speech reference
if (ref == "z_speech") {
pred_data <- ggeffects::ggpredict(model1, terms = c("age_c", "model_type"))
pred_df <- as.data.frame(pred_data)
p <- ggplot2::ggplot(pred_df, ggplot2::aes(x = x, y = predicted, color = group, fill = group)) +
ggplot2::geom_ribbon(ggplot2::aes(ymin = conf.low, ymax = conf.high), alpha = 0.15, color = NA) +
ggplot2::geom_line(linewidth = 1) +
ggplot2::scale_y_continuous(limits = c(-0.1, 0.5), breaks = seq(-0.1, 0.5, by = 0.1)) +
ggplot2::scale_color_manual(
values = c("#c51b7d", "#f4883c", "#276419", "#ffbf00"),
labels = c("Speech", "Mixed", "Music", "Stacked")
) +
ggplot2::scale_fill_manual(
values = c("#c51b7d", "#f4883c", "#276419", "#ffbf00"),
labels = c("Speech", "Mixed", "Music", "Stacked")
) +
ggplot2::scale_x_continuous(
name = "Age (years)",
breaks = log(c(4, 6, 8, 10, 12, 15, 18, 22)) - log_age_mean,
labels = c(4, 6, 8, 10, 12, 15, 18, 22),
limits = c(x_min, x_max)
) +
ggplot2::labs(title = NULL, y = "Fisher Z-transformed Correlation", color = "Model Type", fill = "Model Type") +
ggplot2::guides(
color = ggplot2::guide_legend(override.aes = list(linewidth = 2)),
fill = "none"
) +
ggplot2::theme_classic(base_family = "Arial") +
ggplot2::theme(
axis.title = ggplot2::element_text(size = 14),
axis.text = ggplot2::element_text(size = 12),
axis.line = ggplot2::element_line(linewidth = 0.6, colour = "black"),
legend.position = "right",
legend.justification = "top",
legend.title = ggplot2::element_text(size = 12),
legend.text = ggplot2::element_text(size = 11),
legend.background = ggplot2::element_blank(),
legend.key = ggplot2::element_blank(),
plot.margin = ggplot2::margin(40, 20, 10, 10)
)
ggplot2::ggsave(file.path(save_dir, paste0(anat, "_ref_", ref, ".png")),
plot = p, width = 8, height = 5, dpi = 300,
device = grDevices::png, type = "cairo")
ggplot2::ggsave(file.path(save_dir, paste0(anat, "_ref_", ref, ".pdf")),
plot = p, width = 8, height = 5, device = cairo_pdf)
}
cat("Model 1: Combined (Reference:", ref, ")\n")
print(summary(model1))
print(anova(model1))
cat("\n")
}
}
sink()
